  <!-- SEMANA -->
  <div class="tab-content" id="tab-weekly">
    <div class="section-title">La semana que pasó</div>
    <div class="news-grid">
      <div class="news-card"><h3>Mercado & Economía</h3><ul class="news-items">
        <li class="news-item"><span class="news-tag tag-bcra">BCRA</span>Compras 5d: US$529M — YTD: US$4.457M.</li>
        <li class="news-item"><span class="news-tag tag-macro">MACRO</span>Caputo señaló inflación de marzo por encima de febrero, impulsada por combustibles (Medio Oriente) y estacionales (ciclo lectivo). Balanz estima 3,2% m/m.</li>
        <li class="news-item"><span class="news-tag tag-macro">MACRO</span>Presidente de YPF anunció precios de combustibles estables los próximos 45 días.</li>
        <li class="news-item"><span class="news-tag tag-macro">MACRO</span>Tesoro colocó US$131M adicionales en AO27/AO28. Acumulado US$931M en Bonar27 y Bonar28.</li>
        <li class="news-item"><span class="news-tag tag-macro">MACRO</span>Liquidación agro en marzo: US$2.03bn, mayor para ese mes desde 2022 (+8% i.a.). 1T26: US$5.2bn.</li>
        <li class="news-item"><span class="news-tag tag-macro">MACRO</span>Pobreza cayó a 28,2% en 2S25 (mínimo desde 2018), indigencia a 6,3%, desde 38,1% a fines de 2024.</li>
      </ul></div>
      <div class="news-card"><h3>Política & Legal</h3><ul class="news-items">
        <li class="news-item"><span class="news-tag tag-pol">POL</span>Gobierno convocará sesión en Diputados para reforma Ley de Glaciares (expectativa ≥130 votos).</li>
        <li class="news-item"><span class="news-tag tag-reg">LEGAL</span>Tribunal laboral suspendió 81 artículos de la reforma laboral por cautelar de la CGT.</li>
        <li class="news-item"><span class="news-tag tag-reg">LEGAL</span>Justicia ordenó al Gobierno cumplir ley de financiamiento universitario y actualizar salarios docentes.</li>
      </ul></div>
    </div>
  </div>

  <!-- AGENDA -->
  <div class="tab-content" id="tab-calendar">
    <div class="section-title">A monitorear esta semana</div>
    <div class="news-card" style="margin-bottom:24px"><ul class="news-items">
      <li class="news-item">BCRA publicará el REM. Atentos a revisiones de expectativas de inflación por impacto de combustibles.</li>
      <li class="news-item">Novedades revisión acuerdo FMI.</li>
      <li class="news-item">Contexto global: commodities relevantes para términos de intercambio.</li>
    </ul></div>
    <div class="section-title">Calendario de datos</div>
    <div class="table-wrapper"><div style="overflow-x:auto"><table><thead><tr><th>Fecha</th><th>Dato</th><th class="right">Balanz</th><th class="right">REM</th></tr></thead><tbody>
      <tr><td class="calendar-date">08/04</td><td>REM de marzo</td><td class="right perf-muted">—</td><td class="right perf-muted">—</td></tr>
      <tr><td class="calendar-date">14/04</td><td>IPC de marzo</td><td class="right" style="font-weight:600">3,2% m/m</td><td class="right perf-muted">—</td></tr>
      <tr><td class="calendar-date">16/04</td><td>Resultado fiscal de marzo</td><td class="right perf-muted">—</td><td class="right perf-muted">—</td></tr>
      <tr><td class="calendar-date">20/04</td><td>ICA de marzo</td><td class="right perf-muted">—</td><td class="right perf-muted">—</td></tr>
      <tr><td class="calendar-date">22/04</td><td>EMAE de febrero</td><td class="right perf-muted">—</td><td class="right perf-muted">—</td></tr>
    </tbody></table></div></div>
  </div>

  <div class="footer"><p>Fuente: Balanz Research, BBG, BCRA, INDEC, MECON, UTDT. Precios al 1 de abril de 2026. Este dashboard es informativo y no constituye recomendación de inversión. Balanz Capital Valores S.A.U.</p></div>
</div>

<script>
function showTab(id,btn){document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));document.querySelectorAll('.tab').forEach(el=>el.classList.remove('active'));document.getElementById('tab-'+id).classList.add('active');btn.classList.add('active');if(id==='rendimientos')setTimeout(()=>{renderCurveChart();renderProvChart();},60);}
function showSubTab(id,btn){const parent=btn.closest('.tab-content');parent.querySelectorAll('.sub-content').forEach(el=>el.classList.remove('active'));parent.querySelectorAll('.sub-tab').forEach(el=>el.classList.remove('active'));document.getElementById('sub-'+id).classList.add('active');btn.classList.add('active');if(id==='soberanos')setTimeout(renderCurveChart,60);if(id==='subsoberanos')setTimeout(renderProvChart,60);}
function renderCurveChart(){const c=document.getElementById('curveChart');if(!c||c.offsetWidth===0)return;const w=c.offsetWidth,h=c.offsetHeight;const p={t:35,r:30,b:50,l:55};const pw=w-p.l-p.r,ph=h-p.t-p.b;const data=[['GD29',1.8,8.7,'GD'],['GD30',2.2,9.5,'GD'],['GD35',5.2,10.4,'GD'],['GD38',4.5,10.6,'GD'],['GD41',6.2,10.5,'GD'],['GD46',7.0,10.3,'GD'],['AL29',1.5,10.7,'AL'],['AL30',2.3,10.8,'AL'],['AL35',5.4,10.8,'AL'],['AL38',4.3,11.3,'AL'],['AL41',6.3,10.7,'AL'],['AL29N',3.5,11.1,'AL'],['AL27',1.0,7.4,'AL'],['BPOC7',0.8,8.3,'BP'],['BPOD7',0.9,7.9,'BP'],['BPO28A',1.8,10.5,'BP'],['BPO28B',2.5,9.9,'BP']];const xMin=0,xMax=8,yMin=6,yMax=12;const sx=d=>p.l+((d-xMin)/(xMax-xMin))*pw;const sy=y=>p.t+(1-(y-yMin)/(yMax-yMin))*ph;const col={GD:'#3b82f6',AL:'#06b6d4',BP:'#94a3b8'};let s=`<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" style="font-family:'DM Sans',sans-serif">`;for(let y=6;y<=12;y++){const yy=sy(y);s+=`<line x1="${p.l}" y1="${yy}" x2="${w-p.r}" y2="${yy}" stroke="#1e2a45"/><text x="${p.l-10}" y="${yy+4}" text-anchor="end" fill="#64748b" font-size="11" font-family="'Space Mono',monospace">${y}%</text>`;}for(let x=0;x<=8;x+=2){const xx=sx(x);s+=`<line x1="${xx}" y1="${p.t}" x2="${xx}" y2="${h-p.b}" stroke="#1e2a45" stroke-dasharray="4,4"/><text x="${xx}" y="${h-p.b+20}" text-anchor="middle" fill="#64748b" font-size="11" font-family="'Space Mono',monospace">${x}</text>`;}s+=`<text x="${w/2}" y="${h-5}" text-anchor="middle" fill="#64748b" font-size="11" font-family="'Space Mono',monospace">Duration</text>`;s+=`<text x="14" y="${h/2}" text-anchor="middle" fill="#64748b" font-size="11" font-family="'Space Mono',monospace" transform="rotate(-90,14,${h/2})">TIR (%)</text>`;['GD','AL'].forEach(sr=>{const pts=data.filter(d=>d[3]===sr).sort((a,b)=>a[1]-b[1]);if(pts.length<2)return;const pd=pts.map((q,i)=>`${i===0?'M':'L'}${sx(q[1]).toFixed(1)},${sy(q[2]).toFixed(1)}`).join(' ');s+=`<path d="${pd}" fill="none" stroke="${col[sr]}" stroke-width="1.5" stroke-dasharray="6,4" opacity="0.35"/>`;});data.forEach(([nm,dur,tir,sr])=>{const cx=sx(dur),cy=sy(tir),cl=col[sr];const rec=nm==='GD41'||nm==='AL30';const r=rec?7:5;s+=`<circle cx="${cx}" cy="${cy}" r="${r}" fill="${cl}" opacity="0.9" stroke="${rec?'#fff':'none'}" stroke-width="${rec?2:0}"/>`;const ly=cy-12;s+=`<text x="${cx}" y="${ly}" text-anchor="middle" fill="${cl}" font-size="10" font-weight="${rec?700:500}">${nm}</text>`;if(rec)s+=`<text x="${cx}" y="${ly-11}" text-anchor="middle" fill="${cl}" font-size="9" font-weight="700">★</text>`;});s+=`</svg>`;c.innerHTML=s;}
function renderProvChart(){const c=document.getElementById('provChart');if(!c||c.offsetWidth===0)return;const w=c.offsetWidth,h=c.offsetHeight;const p={t:30,r:30,b:50,l:55};const pw=w-p.l-p.r,ph=h-p.t-p.b;const data=[['BUEAIR27',0.3,5.6],['BUEAIR33',4.5,12.2],['PROVSF27',0.7,8.8],['PROVSF34',3.5,16.3],['NEUQUE30G',1.8,8.3],['NEUQUE30',2.2,9.9],['MENDOZ29',1.2,9.4],['PDCAR27',0.6,7.1],['PDCAR29',1.6,11.0],['PDCAR32',4.2,14.6],['PDCAR35',3.0,17.2],['BUENOS37A',4.8,16.1],['SALTA27',0.9,9.5],['JUJUY27',0.7,8.1],['CHUBUT30',2.0,8.6],['FUEGO27',1.9,10.6],['ENTRIO28',1.5,9.5],['CHACO28',1.1,10.8],['PRN28',1.3,10.1]];const xMin=0,xMax=6,yMin=4,yMax=18;const sx=d=>p.l+((d-xMin)/(xMax-xMin))*pw;const sy=y=>p.t+(1-(y-yMin)/(yMax-yMin))*ph;let s=`<svg viewBox="0 0 ${w} ${h}" xmlns="http://www.w3.org/2000/svg" style="font-family:'DM Sans',sans-serif">`;for(let y=4;y<=18;y+=2){const yy=sy(y);s+=`<line x1="${p.l}" y1="${yy}" x2="${w-p.r}" y2="${yy}" stroke="#1e2a45"/><text x="${p.l-10}" y="${yy+4}" text-anchor="end" fill="#64748b" font-size="11" font-family="'Space Mono',monospace">${y}%</text>`;}for(let x=0;x<=6;x++){const xx=sx(x);s+=`<line x1="${xx}" y1="${p.t}" x2="${xx}" y2="${h-p.b}" stroke="#1e2a45" stroke-dasharray="4,4"/><text x="${xx}" y="${h-p.b+20}" text-anchor="middle" fill="#64748b" font-size="11" font-family="'Space Mono',monospace">${x}</text>`;}s+=`<text x="${w/2}" y="${h-5}" text-anchor="middle" fill="#64748b" font-size="11" font-family="'Space Mono',monospace">Duration</text>`;s+=`<text x="14" y="${h/2}" text-anchor="middle" fill="#64748b" font-size="11" font-family="'Space Mono',monospace" transform="rotate(-90,14,${h/2})">TIR (%)</text>`;data.forEach(([nm,dur,tir])=>{const cx=sx(dur),cy=sy(tir);const rec=nm==='PROVSF34';const cl=rec?'#3b82f6':'#94a3b8';const r=rec?7:4;s+=`<circle cx="${cx}" cy="${cy}" r="${r}" fill="${cl}" opacity="0.85" stroke="${rec?'#fff':'none'}" stroke-width="${rec?2:0}"/>`;s+=`<text x="${cx+8}" y="${cy+3}" fill="${rec?'#3b82f6':'#64748b'}" font-size="${rec?11:9}" font-weight="${rec?700:400}">${nm}${rec?' ★':''}</text>`;});s+=`</svg>`;c.innerHTML=s;}
window.addEventListener('load',()=>{renderCurveChart();renderProvChart();});
window.addEventListener('resize',()=>{renderCurveChart();renderProvChart();});
</script>
</body>
</html>
